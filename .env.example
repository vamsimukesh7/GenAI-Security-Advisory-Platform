# ════════════════════════════════════════════════════════════════
# Virtue-AI — Production Environment Configuration
# ════════════════════════════════════════════════════════════════
# Target Server: Dell Precision 5820 Tower
# Hardware: Xeon W-2145 | 32GB RAM | Quadro P1000 (4GB VRAM)
# ════════════════════════════════════════════════════════════════

# ── Security Keys (CHANGE THESE WITH STRONG RANDOM STRINGS) ──
SERVICE_SECRET_KEY=your_service_hmac_secret_key_min_32_chars
JWT_SECRET_KEY=your_jwt_signing_secret_key_min_32_chars
POSTGRES_PASSWORD=your_postgres_db_password_here

# ── Database Configuration ──
POSTGRES_USER=virtue
POSTGRES_DB=virtue
# Used by API and Ingester (update password in string if changed)
DATABASE_URL=postgresql://virtue:your_postgres_db_password_here@postgres:5432/virtue

# ── Vector Store (Qdrant) ──
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── LLM Tuning (Optimized for Quadro P1000 4GB VRAM) ──
OLLAMA_BASE_URL=http://ollama:11434
DEFAULT_MODEL_NAME=gemma4:e2b
LLM_REQUEST_TIMEOUT=300        # 5 min max per request
LLM_NUM_PREDICT=512            # Output tokens (saves VRAM)
LLM_NUM_CTX=4096               # Context window (must fit in 4GB VRAM)
LLM_TEMPERATURE=0.2            # Low = deterministic output

# ── Performance & SLA ──
SLA_LATENCY_THRESHOLD_MS=8000  # 8s — realistic for Quadro P1000

# ── Knowledge Pipeline (Fetcher & Ingester) ──
INBOX_PATH=/data/knowledge-inbox
KB_FETCH_INTERVAL_HOURS=6      # How often to fetch new CVEs
KB_POLL_INTERVAL_SECONDS=60    # How often ingester checks inbox
NVD_API_KEY=your_nvd_api_key_here

# ── Langfuse LLM Observability (Optional) ──
# Self-hosted Langfuse for tracing, prompt management, and evaluation.
# Leave LANGFUSE_PUBLIC_KEY blank to disable tracing entirely (zero overhead).
# Start Langfuse services with: docker compose --profile langfuse up -d
LANGFUSE_PUBLIC_KEY=pk-lf-virtue
LANGFUSE_SECRET_KEY=sk-lf-virtue
LANGFUSE_BASE_URL=http://langfuse-web:3000
LANGFUSE_DB_PASSWORD=your_langfuse_db_password_here
LANGFUSE_CH_PASSWORD=your_langfuse_clickhouse_password_here
LANGFUSE_MINIO_USER=langfuse
LANGFUSE_MINIO_PASSWORD=your_langfuse_minio_password_here
LANGFUSE_NEXTAUTH_SECRET=your_langfuse_nextauth_secret_here
LANGFUSE_SALT=your_langfuse_salt_here
